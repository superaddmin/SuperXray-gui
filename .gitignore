# Ignore build and distribution directories
backup/
bin/
dist/
release/
node_modules/
playwright-report/
test-results/
tests/e2e/.auth/

# Ignore compiled binaries
main

# Ignore script and executable files
/release.sh
/x-ui

# Ignore OS specific files
.DS_Store
Thumbs.db

# Ignore Go build files
*.exe
*.db
*.db-shm
*.db-wal
x-ui.db
superxray.db

# Ignore Docker specific files
docker-compose.override.yml

# Ignore .env (Environment Variables) file
.env

# Ignore local operational audit artifacts containing real server/subscription/proxy details.
docs/server-*-inbound-subscription-audit-*.txt
docs/*subscription-audit*.txt
docs/private-ops/
*.secrets.*
*.credentials.*

# Ignore compiled binary (build output)
SuperXray-gui

# Keep project documentation trackable; only generated report artifacts should be ignored elsewhere.
!/docs/
!/docs/*.md
!/docs/superpowers/
!/docs/superpowers/**
