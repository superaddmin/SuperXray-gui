!.env.example
!.env.*.example

# Ignore local operational audit artifacts containing real server/subscription/proxy details.
docs/server-*-inbound-subscription-audit-*.txt
docs/*subscription-audit*.txt
docs/private-ops/
*.secrets.*
*.credentials.*
**/*secrets*
**/*credentials*
!web/service/shadowsocks_credentials.go
!web/service/shadowsocks_credentials_test.go

# Ignore compiled binary (build output)
